# ---- Copy this file to .env and adjust values. NEVER commit .env ----

# ---- PostgreSQL ----
POSTGRES_DB=cloudbox
POSTGRES_USER=cloudbox
POSTGRES_PASSWORD=cloudbox_dev_password

# ---- MinIO (S3-compatible object storage) ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=cloudbox-files

# ---- Backend (Spring Boot) ----
# Datasource (points at the postgres service inside the compose network)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/cloudbox
SPRING_DATASOURCE_USERNAME=cloudbox
SPRING_DATASOURCE_PASSWORD=cloudbox_dev_password

# S3 / MinIO endpoint (points at the minio service inside the compose network)
STORAGE_ENDPOINT=http://minio:9000
# Browser-reachable endpoint used to sign preview/download URLs.
# Dev: the host-mapped MinIO port. Prod: a public MinIO/S3 URL the browser can reach.
STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=cloudbox-files
STORAGE_REGION=us-east-1

# JWT (CHANGE THIS in production — must be a long random base64 string, >= 256 bits)
JWT_SECRET=ZmFrZS1kZXYtc2VjcmV0LWNoYW5nZS1tZS1wbGVhc2UtMTIzNDU2Nzg5MA==
JWT_EXPIRATION_MS=86400000

# ---- Google OAuth (optional) ----
# Leave blank to keep Google sign-in disabled (email/password still works).
# Create credentials at https://console.cloud.google.com/apis/credentials
#   - OAuth client type: Web application
#   - Authorized redirect URI:  http://localhost:8080/login/oauth2/code/google
#   - Authorized JavaScript origins: http://localhost:3000 and http://localhost:8080
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Where the backend sends the browser after Google login (SPA callback route)
OAUTH_SUCCESS_REDIRECT=http://localhost:3000/oauth/callback

# Per-user storage quota in bytes (default 1 GB)
STORAGE_QUOTA_BYTES=1073741824

# ---- Production only (docker-compose.prod.yml + Caddy) ----
# Public domain Caddy will obtain HTTPS for. Use "localhost" for local testing.
DOMAIN=localhost
# Public origin used for CORS (must match how the browser reaches the app).
PUBLIC_URL=https://localhost
